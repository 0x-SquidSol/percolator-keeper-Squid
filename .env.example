# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_RPC_WS_URL=wss://api.mainnet-beta.solana.com

# Keeper wallet — base58 private key or path to keypair JSON file
CRANK_KEYPAIR=

# Supabase (for market registry)
# Use the anon key only — keeper must NOT have SUPABASE_SERVICE_ROLE_KEY (PERC-8232)
SUPABASE_URL=
SUPABASE_KEY=

# Sentry (optional)
SENTRY_DSN=

# Health check port
KEEPER_HEALTH_PORT=8081

# Shared secret for /register endpoint (optional)
# KEEPER_REGISTER_SECRET=

# ADL service (disabled by default — requires on-chain T8+T10)
# ADL_ENABLED=true
# ADL_INTERVAL_MS=10000
# ADL_MAX_TX_PER_SCAN=10
# ADL_INSURANCE_THRESHOLD_LAMPORTS=0
# ADL_INSURANCE_UTIL_THRESHOLD_BPS=8000

# Mainnet mode (set FORCE_MAINNET=1 to confirm)
# NETWORK=mainnet
# FORCE_MAINNET=1
# RPC_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_KEY
# PROGRAM_ID=GM8zjJ8LTBMv9xEsverh6H6wLyevgMHEJXcEzyY3rY24

# Helius Sender (Phase 1 performance upgrade — opt-in)
# Requires SOLANA_RPC_URL to be a Helius mainnet endpoint.
# When true, sendWithRetryKeeper routes via https://sender.helius-rpc.com/fast
# with skipPreflight + Jito tip + program-specific priority fee estimate.
# USE_HELIUS_SENDER=true
# HELIUS_PRIORITY_LEVEL=High       # Min | Low | Medium | High | VeryHigh
# JITO_TIP_LAMPORTS=200000         # 0.0002 SOL minimum for dual-routing

# Enhanced WebSocket (Phase 2 — indexer real-time streaming)
# HELIUS_ATLAS_WS_URL=wss://atlas-mainnet.helius-rpc.com?api-key=YOUR_KEY

# Oracle push rate limit (ms between same-market pushes; default 5000)
# ORACLE_RATE_LIMIT_MS=5000
